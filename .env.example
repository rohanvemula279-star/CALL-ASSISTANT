# Application
APP_NAME=ai-phone-assistant
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
ENVIRONMENT=development

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=minimax-m3
OLLAMA_TIMEOUT=60

# Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_PRELOAD=true

# Piper
PIPER_VOICE=en_US-amy-medium
PIPER_PRELOAD=true
PIPER_OUTPUT_DIR=/app/storage/tts

# Storage
STORAGE_DIR=/app/storage
SQLITE_PATH=/app/storage/conversations.db

# Asterisk
ASTERISK_HOST=asterisk
ASTERISK_HTTP_PORT=8088

# Telegram (both required to send notifications; otherwise disabled)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT=10

# Public URL of this service (used in dashboard links inside Telegram)
BASE_URL=http://localhost:8000
